---
import { getCollection, render } from 'astro:content';

const faqs = (await getCollection('faqs'))
  .sort((a, b) => a.data.order - b.data.order);

const rendered = await Promise.all(
  faqs.map(async (faq) => ({
    faq,
    Content: (await render(faq)).Content,
  }))
);
---

<section class="faq" id="faq" aria-labelledby="faq-title">
  <div class="faq-inner">
    <div class="faq-header reveal">
      <div class="section-num">06</div>
      <h2 class="section-title" id="faq-title">Good <em>questions.</em></h2>
    </div>

    <dl class="faq-list">
      {rendered.map(({ faq, Content }) => (
        <div class="faq-item reveal">
          <details>
            <summary>
              <span class="faq-question">{faq.data.question}</span>
              <span class="faq-icon" aria-hidden="true">
                <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
                  <path d="M3 6l5 5 5-5"/>
                </svg>
              </span>
            </summary>
            <div class="faq-answer">
              <Content />
            </div>
          </details>
        </div>
      ))}
    </dl>
  </div>
</section>

<style>
  .faq {
    padding: 120px 40px;
    background: var(--bg-deep);
  }

  .faq-inner {
    max-width: 860px;
    margin: 0 auto;
  }

  .faq-header {
    margin-bottom: 72px;
  }

  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .faq-item {
    border-top: 1px solid var(--rule);
  }
  .faq-item:last-child {
    border-bottom: 1px solid var(--rule);
  }

  details { width: 100%; }

  summary {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 24px;
    padding: 26px 0;
    cursor: pointer;
    list-style: none;
    user-select: none;
  }
  summary::-webkit-details-marker { display: none; }
  summary::marker { display: none; }

  summary:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
    border-radius: 2px;
  }

  .faq-question {
    font-family: 'Fraunces', serif;
    font-weight: 400;
    font-size: clamp(18px, 2vw, 22px);
    letter-spacing: -0.01em;
    color: var(--ink);
    line-height: 1.3;
  }

  .faq-icon {
    flex-shrink: 0;
    width: 20px;
    height: 20px;
    color: var(--accent);
    transition: transform 0.3s ease;
  }
  .faq-icon svg { width: 100%; height: 100%; }

  details[open] .faq-icon { transform: rotate(180deg); }
  details[open] .faq-question { color: var(--accent); }

  .faq-answer {
    padding: 0 48px 28px 0;
    color: var(--ink-soft);
    font-size: 16px;
    line-height: 1.7;
  }
  .faq-answer p + p { margin-top: 14px; }

  @media (max-width: 900px) {
    .faq { padding: 80px 20px; }
    .faq-header { margin-bottom: 48px; }
    .faq-answer { padding-right: 0; }
  }
</style>
