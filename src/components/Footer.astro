---
const year = new Date().getFullYear();
---

<footer>
  <div class="footer-inner">
    <div class="footer-brand-col">
      <div class="footer-brand" aria-label="A Good Hang">
        A Good <em>Hang</em>
      </div>
      <p class="footer-tag">
        A small wallpaper studio in Winston-Salem, North Carolina.
        Sourcing, styling, and expert installation across the Triad.
      </p>
    </div>

    <nav class="footer-col" aria-label="Footer navigation">
      <h2 class="footer-heading">Navigate</h2>
      <ul role="list">
        <li><a href="#work">Work</a></li>
        <li><a href="#services">Services</a></li>
        <li><a href="#about">About</a></li>
        <li><a href="#process">Process</a></li>
        <li><a href="#pricing">Pricing</a></li>
        <li><a href="#faq">FAQ</a></li>
        <li><a href="#contact">Contact</a></li>
      </ul>
    </nav>

    <div class="footer-col">
      <h2 class="footer-heading">Get in touch</h2>
      <ul role="list">
        <li><a href="tel:+13364088479">336·408·8479</a></li>
        <li>
          <a href="https://instagram.com/agoodhangws" target="_blank" rel="noopener noreferrer">
            @agoodhangws
          </a>
        </li>
        <li><a href="#contact">Send a message →</a></li>
      </ul>
    </div>
  </div>

  <div class="footer-bottom">
    <div>© {year} A Good Hang · Margaret Proegler</div>
    <div>Winston-Salem, NC</div>
  </div>
</footer>

<style>
  footer {
    background: var(--bg-deep);
    padding: 70px 40px 40px;
    border-top: 1px solid var(--rule);
  }

  .footer-inner {
    max-width: 1400px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: 60px;
    align-items: start;
  }

  .footer-brand {
    font-family: 'Fraunces', serif;
    font-weight: 300;
    font-size: 48px;
    font-style: italic;
    letter-spacing: -0.02em;
    line-height: 1;
    margin-bottom: 16px;
  }
  .footer-brand em { font-style: normal; color: var(--accent); }

  .footer-tag {
    color: var(--ink-soft);
    font-size: 15px;
    max-width: 340px;
    line-height: 1.6;
  }

  .footer-heading {
    font-size: 12px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--ink-mute);
    margin-bottom: 20px;
    font-weight: 500;
    font-family: 'Inter', sans-serif;
  }

  .footer-col ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .footer-col a {
    font-size: 15px;
    color: var(--ink-soft);
    transition: color 0.3s ease;
  }
  .footer-col a:hover,
  .footer-col a:focus-visible { color: var(--accent); }

  .footer-bottom {
    max-width: 1400px;
    margin: 60px auto 0;
    padding-top: 28px;
    border-top: 1px solid var(--rule);
    display: flex;
    justify-content: space-between;
    font-size: 13px;
    color: var(--ink-mute);
    flex-wrap: wrap;
    gap: 12px;
  }

  @media (max-width: 900px) {
    footer { padding: 50px 20px 30px; }
    .footer-inner {
      grid-template-columns: 1fr 1fr;
      gap: 40px;
    }
    .footer-brand-col { grid-column: span 2; }
    .footer-brand { font-size: 36px; }
    .footer-bottom { margin-top: 40px; }
  }

  @media (max-width: 480px) {
    .footer-inner { grid-template-columns: 1fr; }
    .footer-brand-col { grid-column: span 1; }
  }
</style>
