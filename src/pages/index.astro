---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import Marquee from '../components/Marquee.astro';
import Services from '../components/Services.astro';
import Gallery from '../components/Gallery.astro';
import Testimonials from '../components/Testimonials.astro';
import About from '../components/About.astro';
import Process from '../components/Process.astro';
import Pricing from '../components/Pricing.astro';
import FAQ from '../components/FAQ.astro';
import ServiceArea from '../components/ServiceArea.astro';
import ContactForm from '../components/ContactForm.astro';
import Footer from '../components/Footer.astro';
import Lightbox from '../components/Lightbox.astro';
import { getCollection } from 'astro:content';

const faqs = (await getCollection('faqs')).sort((a, b) => a.data.order - b.data.order);

function faqBodyText(body: string | undefined): string {
  if (!body) return '';
  return body.replace(/<!--[\s\S]*?-->/g, '').trim();
}

const localBusiness = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "A Good Hang",
  "description": "Wallpaper sourcing, styling, and installation studio.",
  "areaServed": [
    "Winston-Salem", "Clemmons", "Lewisville", "Kernersville",
    "Greensboro", "High Point", "Summerfield",
  ],
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Winston-Salem",
    "addressRegion": "NC",
    "addressCountry": "US",
  },
  "url": "https://agoodhang.com",
  "sameAs": ["https://instagram.com/agoodhangws"],
};

const faqPage = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map((f) => ({
    "@type": "Question",
    "name": f.data.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faqBodyText(f.body),
    },
  })),
};
---

<Base>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(localBusiness)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqPage)} />
  </Fragment>

  <Nav />
  <main id="main">
    <Hero />
    <Marquee />
    <Services />
    <Gallery />
    <Testimonials />
    <About />
    <Process />
    <Pricing />
    <FAQ />
    <ServiceArea />
    <ContactForm />
  </main>
  <Footer />
  <Lightbox />
</Base>

<script>
  const io = new IntersectionObserver(
    (entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting) {
          e.target.classList.add('shown');
          io.unobserve(e.target);
        }
      });
    },
    { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
  );
  document.querySelectorAll('.reveal').forEach((el) => io.observe(el));
</script>
