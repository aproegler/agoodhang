---
import Base from '../layouts/Base.astro';
---

<Base
  title="Thank you — A Good Hang"
  description="Your message has been received. Margaret will be in touch soon."
>
  <main id="main" class="thanks-page">
    <div class="thanks-inner">
      <p class="thanks-num" aria-hidden="true">✓</p>
      <h1>Thank you.</h1>
      <p class="thanks-sub">
        Margaret will be in touch within a day — usually much sooner.
      </p>
      <a href="/" class="btn-primary">
        Back to the site
        <span class="arrow" aria-hidden="true">→</span>
      </a>
    </div>
  </main>
</Base>

<style>
  .thanks-page {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 60px 20px;
  }

  .thanks-inner {
    max-width: 520px;
    text-align: center;
  }

  .thanks-num {
    font-size: 48px;
    color: var(--accent);
    margin-bottom: 24px;
    line-height: 1;
  }

  h1 {
    font-family: 'Fraunces', serif;
    font-weight: 300;
    font-style: italic;
    font-size: clamp(52px, 8vw, 96px);
    line-height: 0.95;
    letter-spacing: -0.025em;
    color: var(--ink);
    margin-bottom: 28px;
  }

  .thanks-sub {
    font-size: 20px;
    line-height: 1.5;
    color: var(--ink-soft);
    margin-bottom: 48px;
  }
</style>
