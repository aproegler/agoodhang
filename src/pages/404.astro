---
import Base from '../layouts/Base.astro';
---

<Base
  title="Page not found — A Good Hang"
  description="This page doesn't exist. Head back to A Good Hang."
>
  <main id="main" class="not-found">
    <div class="not-found-inner">
      <p class="not-found-num" aria-hidden="true">404</p>
      <h1>Wrong room.</h1>
      <p class="not-found-sub">
        This page doesn't exist — but a well-papered one does.
      </p>
      <a href="/" class="btn-primary">
        Back to the site
        <span class="arrow" aria-hidden="true">→</span>
      </a>
    </div>
  </main>
</Base>

<style>
  .not-found {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 60px 20px;
  }

  .not-found-inner {
    max-width: 520px;
    text-align: center;
  }

  .not-found-num {
    font-family: 'Fraunces', serif;
    font-style: italic;
    font-weight: 300;
    font-size: clamp(80px, 15vw, 160px);
    line-height: 1;
    color: var(--rule);
    margin-bottom: 8px;
    letter-spacing: -0.04em;
  }

  h1 {
    font-family: 'Fraunces', serif;
    font-weight: 300;
    font-style: italic;
    font-size: clamp(40px, 6vw, 72px);
    line-height: 1;
    letter-spacing: -0.025em;
    color: var(--ink);
    margin-bottom: 20px;
  }

  .not-found-sub {
    font-size: 18px;
    line-height: 1.5;
    color: var(--ink-soft);
    margin-bottom: 44px;
  }
</style>
